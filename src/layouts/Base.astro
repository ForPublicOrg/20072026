---
import "../styles/global.css";
import { SITE_NAME, SITE_URL, CONTACT_EMAIL } from "../config";

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = `${SITE_URL}/og-default.png`,
  ogType = "website",
  canonical = new URL(Astro.url.pathname, SITE_URL).toString(),
} = Astro.props;

const pageTitle = `${title} — ${SITE_NAME}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-bg text-text">
    <header class="border-b border-white/10">
      <div
        class="content-col flex items-center justify-between gap-4 py-4"
      >
        <a href="/" class="text-base font-semibold tracking-tight text-text no-underline">
          {SITE_NAME}
        </a>
        <nav class="flex items-center gap-5 text-sm text-muted">
          <a href="/" class="min-h-11 flex items-center no-underline hover:text-text">Feed</a>
          <a href="/timeline/" class="min-h-11 flex items-center no-underline hover:text-text">Timeline</a>
          <a href="/about/" class="min-h-11 flex items-center no-underline hover:text-text">About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-white/10 mt-16">
      <div class="content-col py-8 text-sm text-muted flex flex-col gap-2">
        <p>
          Black Days is an archive of publicly available video and reporting.
          Preservation, discoverability, documentation — not commentary.
        </p>
        <p>
          Corrections &amp; takedowns:{" "}
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="text-accent no-underline hover:underline"
            >{CONTACT_EMAIL}</a
          >
        </p>
        <p>This is an archive, not an endorsement.</p>
      </div>
    </footer>
  </body>
</html>
