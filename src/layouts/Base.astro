---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE_NAME, SITE_URL, CONTACT_EMAIL } from "../config";

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  /**
   * When true, the layout gives up default page padding/scroll: the <body>
   * gets `overflow: hidden` (no document scroll) and <main> is sized to
   * exactly fill the viewport below the header (minus the nav bar height on
   * desktop, where the nav sits in-flow rather than fixed). The page is then
   * responsible for its own scroll container — this is for the full-bleed,
   * fixed-height feed, not for normal content pages.
   */
  fullBleed?: boolean;
}

const {
  title,
  description,
  ogImage = `${SITE_URL}/og-default.png`,
  ogType = "website",
  canonical = new URL(Astro.url.pathname, SITE_URL).toString(),
  fullBleed = false,
} = Astro.props;

const pageTitle = `${title} — ${SITE_NAME}`;

const path = Astro.url.pathname;
const isFeed = path === "/";
const isTimeline = path.startsWith("/timeline");
const isAbout = path.startsWith("/about");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#ffffff" />

    <!-- "Add to Home Screen" / native-app affordances -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
  </head>
  <body class:list={["bg-bg", "text-text", { "is-full-bleed": fullBleed }]}>
    <header class="app-header border-b border-border">
      <div class="content-col flex items-center justify-center py-3">
        <a
          href="/"
          class="text-base font-semibold tracking-tight text-text no-underline"
        >
          {SITE_NAME}
        </a>
      </div>
    </header>

    <nav class="app-nav border-border" aria-label="Primary">
      <a href="/" aria-current={isFeed ? "page" : undefined}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isFeed ? 2.2 : 1.6} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 11.5 12 4l9 7.5" />
          <path d="M5.5 10v9a1 1 0 0 0 1 1H10v-6h4v6h3.5a1 1 0 0 0 1-1v-9" />
        </svg>
        <span>Feed</span>
      </a>
      <a href="/timeline/" aria-current={isTimeline ? "page" : undefined}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isTimeline ? 2.2 : 1.6} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="8.5" />
          <path d="M12 7.5V12l3 2" />
        </svg>
        <span>Timeline</span>
      </a>
      <a href="/about/" aria-current={isAbout ? "page" : undefined}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={isAbout ? 2.2 : 1.6} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="8.5" />
          <path d="M12 11v5.5" />
          <circle cx="12" cy="8" r="0.75" fill="currentColor" stroke="none" />
        </svg>
        <span>About</span>
      </a>
    </nav>

    <main>
      <slot />
    </main>

    {
      !fullBleed && (
        <footer class="border-t border-border">
          <div class="content-col py-8 text-sm text-muted flex flex-col gap-2">
            <p>
              Black Days is an archive of publicly available video and reporting.
              Preservation, discoverability, documentation — not commentary.
            </p>
            <p>
              Corrections &amp; takedowns:{" "}
              <a
                href={`mailto:${CONTACT_EMAIL}`}
                class="text-accent no-underline hover:underline"
                >{CONTACT_EMAIL}</a
              >
            </p>
            <p>This is an archive, not an endorsement.</p>
          </div>
        </footer>
      )
    }
  </body>
</html>

<style>
  .app-header {
    position: sticky;
    top: 0;
    z-index: 40;
    height: var(--app-header-h);
    background: rgba(255, 255, 255, 0.85);
  }

  @supports (backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px)) {
    .app-header {
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
  }

  .app-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    display: flex;
    justify-content: space-around;
    align-items: stretch;
    height: var(--app-nav-h);
    background: rgba(255, 255, 255, 0.85);
    border-top: 1px solid var(--color-border);
    padding-bottom: env(safe-area-inset-bottom);
  }

  @supports (backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px)) {
    .app-nav {
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
  }

  .app-nav a {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    min-height: 44px;
    min-width: 44px;
    padding: 6px 4px;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 11px;
    line-height: 1.2;
  }

  .app-nav a[aria-current="page"] {
    color: var(--color-text);
    font-weight: 600;
  }

  .app-nav svg {
    width: 24px;
    height: 24px;
  }

  /* Default (non-full-bleed) pages: leave room so content isn't hidden
     behind the fixed bottom tab bar. */
  body:not(.is-full-bleed) main {
    padding-bottom: calc(var(--app-nav-h) + env(safe-area-inset-bottom));
  }

  /* Full-bleed pages own their scroll: no document scroll, main fills the
     exact remaining viewport below the header. The fixed bottom nav floats
     translucently over the content, so no extra padding is added here. */
  body.is-full-bleed {
    height: 100svh;
    height: 100dvh;
    overflow: hidden;
  }

  body.is-full-bleed main {
    height: calc(100svh - var(--app-header-h));
    height: calc(100dvh - var(--app-header-h));
    overflow: hidden;
  }

  /* >=768px: the bottom tab bar becomes a slim top bar so desktop doesn't
     look like a stretched phone. It sits in-flow directly under the header
     rather than fixed. */
  @media (min-width: 768px) {
    .app-nav {
      position: static;
      justify-content: center;
      gap: 2.5rem;
      height: var(--app-nav-h-desktop);
      border-top: none;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: 0;
    }

    .app-nav a {
      flex: none;
      flex-direction: row;
      min-height: 40px;
      gap: 6px;
      font-size: 13px;
    }

    .app-nav svg {
      width: 18px;
      height: 18px;
    }

    body:not(.is-full-bleed) main {
      padding-bottom: 0;
    }

    body.is-full-bleed main {
      height: calc(100svh - var(--app-header-h) - var(--app-nav-h-desktop));
      height: calc(100dvh - var(--app-header-h) - var(--app-nav-h-desktop));
    }
  }
</style>
