---
import type { TimelineEvent, VideoEntry } from "../lib/schema";
import { MEDIA_BASE } from "../config";

export interface Props {
  event: TimelineEvent;
  videos: VideoEntry[];
}

const { event, videos } = Astro.props;

const eventTime = new Date(event.time).toLocaleString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
});
---

<li class="timeline-event relative pl-6 pb-10">
  <div class="absolute left-0 top-1.5 h-2.5 w-2.5 -translate-x-1/2 rounded-full border-2 border-bg bg-accent"></div>
  <time datetime={event.time} class="block font-mono text-xs text-muted">
    {eventTime}
  </time>
  <h3 class="mt-1 text-base font-semibold leading-snug">{event.title}</h3>
  <p class="mt-1 text-sm leading-relaxed text-muted">{event.description}</p>

  {
    videos.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-3">
        {videos.map((video) => (
          <a
            href={`/video/${video.id}/`}
            class="group flex w-28 flex-col gap-1.5 no-underline"
          >
            <img
              src={`${MEDIA_BASE}${video.media.thumbnail}`}
              alt={video.title}
              width="112"
              height="199"
              loading="lazy"
              class="aspect-[9/16] w-full rounded-md border border-border bg-surface object-cover"
            />
            <span class="line-clamp-2 text-xs text-muted group-hover:text-text">
              {video.title}
            </span>
          </a>
        ))}
      </div>
    )
  }
</li>

<style>
  .timeline-event {
    border-left: 1px solid var(--color-border);
  }

  .timeline-event:last-child {
    border-left-color: transparent;
  }
</style>
