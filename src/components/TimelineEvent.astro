---
import type { TimelineEvent, VideoEntry } from "../lib/schema";
import { MEDIA_BASE } from "../config";

export interface Props {
  event: TimelineEvent;
  videos: VideoEntry[];
}

const { event, videos } = Astro.props;

// Date only — no clock time. The `time` field holds a date-only ISO string
// ("2026-05-15") and we have never had an hour for any of these events.
// Formatting with hour/minute previously invented one: a date-only string
// parses as UTC midnight, so the old toLocaleString rendered a bogus
// "5:30 AM" that looked like sourced precision and wasn't.
//
// timeZone: "UTC" is load-bearing for the same reason — without it, a
// visitor west of Greenwich renders UTC midnight as the PREVIOUS day, so
// the march on Parliament would date-stamp 19 July for readers in the US.
const eventDate = new Date(event.time).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

// Same date-only, UTC-pinned formatting as the event date (see above for why).
const formatStatementDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });

// Human labels for where a statement was made. Kept factual and flat — the
// archive describes the channel, it does not characterise the statement.
const KIND_LABELS: Record<string, string> = {
  tweet: "On X",
  address: "Public address",
  press: "Press statement",
  parliament: "In Parliament",
  court: "In court",
  interview: "Interview",
};
---

<li class="timeline-event relative pl-6 pb-10">
  <div class="absolute left-0 top-1.5 h-2.5 w-2.5 -translate-x-1/2 rounded-full border-2 border-bg bg-accent"></div>
  <time datetime={event.time} class="block font-mono text-xs text-muted">
    {eventDate}
  </time>
  <h3 class="mt-1 text-base font-semibold leading-snug">{event.title}</h3>
  <p class="mt-1 text-sm leading-relaxed text-muted">{event.description}</p>

  {
    event.image && (
      <figure class="m-0 mt-3">
        <img
          src={event.image.src}
          alt={event.image.alt}
          width={event.image.width}
          height={event.image.height}
          loading="lazy"
          decoding="async"
          class="h-auto w-full rounded-lg border border-border bg-surface"
        />
        <figcaption class="mt-1.5 text-xs leading-relaxed text-tertiary">
          {event.image.caption}{" "}
          <a
            href={event.image.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-link no-underline hover:underline"
          >
            {event.image.credit}
            <span aria-hidden="true"> &#8599;</span>
            <span class="sr-only"> (opens in a new tab)</span>
          </a>
        </figcaption>
      </figure>
    )
  }

  {
    event.statements && event.statements.length > 0 && (
      <div class="mt-3 flex flex-col gap-3">
        {event.statements.map((statement) => (
          <figure class="statement m-0">
            <figcaption class="text-xs leading-relaxed">
              <span class="font-semibold text-text">{statement.speaker}</span>
              <span class="text-muted"> — {statement.role}</span>
              <span class="text-tertiary">
                {" "}&middot; {KIND_LABELS[statement.kind] ?? statement.kind}
                {" "}&middot; {formatStatementDate(statement.date)}
              </span>
            </figcaption>
            <blockquote class="m-0 mt-1 text-sm leading-relaxed text-muted">
              &ldquo;{statement.quote}&rdquo;
            </blockquote>
            {statement.context && (
              <p class="m-0 mt-1 text-xs leading-relaxed text-tertiary">{statement.context}</p>
            )}
            <p class="m-0 mt-1 text-xs leading-relaxed">
              <a
                href={statement.source.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-link no-underline hover:underline"
              >
                {statement.source.title}
                <span aria-hidden="true"> &#8599;</span>
                <span class="sr-only"> (opens in a new tab)</span>
              </a>
            </p>
          </figure>
        ))}
      </div>
    )
  }

  {
    event.sources && event.sources.length > 0 && (
      <ul class="mt-2 flex flex-col gap-1">
        {event.sources.map((source) => (
          <li class="text-xs leading-relaxed">
            <a
              href={source.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-link no-underline hover:underline"
            >
              {source.title}
              <span aria-hidden="true"> &#8599;</span>
              <span class="sr-only"> (opens in a new tab)</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }

  {
    videos.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-3">
        {videos.map((video) => (
          <div class="flex w-40 flex-col gap-1.5 sm:w-48">
            <div
              class="flex items-center justify-center overflow-hidden rounded-md border border-border bg-letterbox"
              style={`aspect-ratio: ${video.media.width} / ${video.media.height};`}
            >
              <video
                controls
                preload="none"
                poster={`${MEDIA_BASE}${video.media.thumbnail}`}
                src={`${MEDIA_BASE}${video.media.video}`}
                width={video.media.width}
                height={video.media.height}
                class="h-full w-full object-contain"
              >
                <track kind="captions" />
              </video>
            </div>
            <a
              href={`/video/${video.id}/`}
              class="line-clamp-2 text-xs text-muted no-underline hover:text-text hover:underline"
            >
              {video.title}
            </a>
          </div>
        ))}
      </div>
    )
  }
</li>

<style>
  .timeline-event {
    border-left: 1px solid var(--color-border);
  }

  /* Official statements: quiet inset blocks. A hairline inset border on an
     elevated surface, not an accent colour — what was said is the content,
     the block itself must not editorialise. */
  .statement {
    border-left: 2px solid var(--color-border);
    background: var(--color-surface);
    border-radius: 0 6px 6px 0;
    padding: 0.6rem 0.85rem;
  }

  .timeline-event:last-child {
    border-left-color: transparent;
  }
</style>
