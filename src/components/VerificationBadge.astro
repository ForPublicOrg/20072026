---
import type { VerificationStatus } from "../lib/schema";

export interface Props {
  status: VerificationStatus;
  /**
   * "light"  — on-white surfaces (detail/timeline pages). Text color is
   *            verified >= 4.5:1 against #ffffff (WCAG AA). Default.
   * "scrim"  — over a dark gradient on video (feed cards). Light,
   *            high-contrast text/dot against a near-black scrim.
   */
  variant?: "light" | "scrim";
}

const { status, variant = "light" } = Astro.props;

interface StatusConfig {
  label: string;
  title: string;
  /** Solid color used for text + dot on "light" (on-white). >=4.5:1 vs #fff. */
  light: string;
  /** Solid color used for text + dot on "scrim" (on dark video overlay). */
  scrim: string;
}

// Colors re-derived for the light Instagram-style theme on 2026-07-21
// (previous values were tuned for a dark background and fail AA on white).
// Verified numerically against #ffffff (light) and #000000 (scrim) — see
// docs/design-spec.md §9 for the full contrast table. Muted/informational
// hues throughout — never alarmist, per verification-policy.md.
const CONFIG: Record<VerificationStatus, StatusConfig> = {
  verified: {
    label: "Verified",
    title:
      "Location, date, and source independently confirmed; no signs of manipulation.",
    light: "#146c2e", // 6.53:1 vs #fff
    scrim: "#5fd88a", // 11.68:1 vs #000
  },
  "likely-verified": {
    label: "Likely verified",
    title:
      "Location and date each supported by a strong indicator; full corroboration incomplete.",
    light: "#0d6b6b", // 6.30:1 vs #fff
    scrim: "#5eead4", // 14.20:1 vs #000
  },
  "partially-verified": {
    label: "Partially verified",
    title: "Some claims are confirmed; see the description for which parts.",
    light: "#7a5900", // 6.45:1 vs #fff
    scrim: "#fbbf24", // 12.58:1 vs #000
  },
  unverified: {
    label: "Unverified",
    title: "Nothing beyond the existence of the public post has been checked.",
    light: "#595959", // 7.00:1 vs #fff
    scrim: "#e5e5e5", // 16.67:1 vs #000
  },
  "context-unclear": {
    label: "Context unclear",
    title:
      "Footage may be real but its claimed date, place, or framing is in question.",
    light: "#9a4200", // 6.66:1 vs #fff
    scrim: "#fb923c", // 9.28:1 vs #000
  },
};

const { label, title, light, scrim } = CONFIG[status];
const color = variant === "scrim" ? scrim : light;

const chipStyle =
  variant === "scrim"
    ? `background-color: rgba(0,0,0,0.55); border: 1px solid ${color}66; color: ${color};`
    : `background-color: ${color}14; border: 1px solid ${color}4d; color: ${color};`;
---

<span
  class="verification-badge inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium"
  style={chipStyle}
  title={title}
  data-variant={variant}
>
  <span
    class="inline-block h-1.5 w-1.5 rounded-full"
    style={`background-color: ${color};`}
    aria-hidden="true"></span>
  {label}
</span>
