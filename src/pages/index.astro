---
// Landing page. Until 2026-07-21 this route WAS the feed (see
// docs/design-spec.md §7, "supersedes" note) — the owner decided a visitor
// should land on an explanation of what this archive is and why it exists
// before being dropped into the feed itself, not the other way around. The
// feed now lives at /feed (src/pages/feed.astro), unchanged in behaviour.
import Base from "../layouts/Base.astro";
import { loadVideos, loadTimeline } from "../lib/schema";
import { SITE_URL } from "../config";

const videos = loadVideos();
const timeline = loadTimeline();
const realVideos = videos.filter((v) => !v.sample);
const sampleVideos = videos.filter((v) => v.sample);

const ogImage = `${SITE_URL}/banner/hero-wide.jpg`;
---

<Base
  title="Home"
  description="On 20 July 2026, more than 10,000 people marched towards Parliament in New Delhi. This is an archive of publicly available video from that day, with source attribution and a verification label on every entry."
  ogImage={ogImage}
>
  <h1 class="sr-only">20 07 2026 — The Day India Remembered</h1>

  <picture>
    <source
      media="(min-width: 768px)"
      type="image/webp"
      srcset="/banner/hero-wide-1280.webp 1280w, /banner/hero-wide-1920.webp 1920w"
      sizes="100vw"
    />
    <!-- Portrait poster is natively 864x1821; do not offer widths above 864 —
         upscaling only inflates bytes without adding detail. -->
    <source
      type="image/webp"
      srcset="/banner/hero-portrait-640.webp 640w, /banner/hero-portrait-864.webp 864w"
      sizes="100vw"
    />
    <img
      src="/banner/hero-portrait.jpg"
      alt="Illustration of a crowd behind police barricades facing a domed government building, with Indian flags and scattered examination papers, overlaid with the text 20·07·2026, The Day India Remembered."
      width="864"
      height="1821"
      fetchpriority="high"
      loading="eager"
      decoding="async"
      class="hero-banner"
    />
  </picture>

  <p class="hero-caption">Illustration — not documentary footage</p>

  <div class="content-col pt-5 pb-8">
    <!-- Lead line + CTA come first so both sit above the fold on a phone. The
         fuller account follows underneath for anyone who wants it. -->
    <p class="text-sm leading-relaxed text-muted">
      An archive of publicly available video from 20 July 2026, kept with its
      original sources and labelled by what has actually been verified.
    </p>

    <div class="cta-row">
      <a href="/feed" class="cta-primary">Relive the day</a>
    </div>

    <p class="mt-8 text-sm leading-relaxed text-muted">
      On 20 July 2026, more than 10,000 people marched towards Parliament in
      New Delhi. Police cut mobile internet, closed metro stations and used
      tear gas and batons.
    </p>
    <p class="mt-4 text-sm leading-relaxed text-muted">
      This is an archive of publicly available video from that day and the
      days around it. Every entry keeps its original source and uploader,
      and carries a label saying how much of it has actually been verified.
    </p>

    <p class="counts">
      {realVideos.length} video{realVideos.length === 1 ? "" : "s"} archived
      &middot; {timeline.length} timeline event{timeline.length === 1 ? "" : "s"}
      <span class="counts-note">
        + {sampleVideos.length} sample placeholders in the archive, clearly
        marked, not counted above
      </span>
    </p>

    <nav class="secondary-links" aria-label="More about this archive">
      <a href="/timeline/">Read the timeline</a>
      <a href="/about/">About this archive</a>
    </nav>
  </div>
</Base>

<style>
  .hero-banner {
    display: block;
    width: 100%;
    height: auto;
    /* Matches the portrait poster's native 864x1821 so nothing is distorted. */
    aspect-ratio: 864 / 1821;
    /* At full width on a phone this poster is ~2.1x the viewport width tall,
       which would push the "Relive the day" CTA well below the fold. Cap it and
       anchor to the top so the date/title block stays intact while the CTA
       remains reachable without scrolling. */
    max-height: 54svh;
    object-fit: cover;
    object-position: top center;
    background: var(--color-bg);
  }

  @media (min-width: 768px) {
    .hero-banner {
      aspect-ratio: 2.5 / 1;
      max-height: none;
      object-position: center;
    }
  }

  .hero-caption {
    margin: 0;
    padding: 0.5rem 1rem 0;
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .cta-row {
    margin-top: 1.75rem;
    display: flex;
    justify-content: center;
  }

  .cta-primary {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-bg);
    padding: 0.85rem 2.25rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .cta-primary:hover {
    opacity: 0.9;
  }

  .counts {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .counts-note {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.75rem;
    color: var(--color-tertiary);
  }

  .secondary-links {
    margin-top: 1.75rem;
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.8125rem;
  }

  .secondary-links a {
    color: var(--color-link);
    text-decoration: none;
  }

  .secondary-links a:hover {
    text-decoration: underline;
  }
</style>
