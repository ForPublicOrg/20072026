---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import VideoCard from "../components/VideoCard.astro";
import { loadVideos } from "../lib/schema";

const videos = [...loadVideos()].sort((a, b) => {
  if (a.date !== b.date) return a.date < b.date ? 1 : -1;
  return a.id < b.id ? 1 : -1;
});
---

<Base
  title="Home"
  description="An archive of publicly available video, photos, and reporting documenting a specific protest event. Preservation, discoverability, and historical documentation — not commentary."
>
  <Hero />

  <div id="feed" class="feed">
    {videos.map((video, index) => <VideoCard video={video} index={index} />)}
  </div>
</Base>

<style>
  .feed {
    scroll-snap-type: y proximity;
  }
</style>

<script src="../scripts/feed.ts"></script>
