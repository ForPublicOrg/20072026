---
// Landing page. Apple-product-page style: the entire first viewport is the
// poster illustration (no visible site title/header — the poster carries
// its own titling), a CTA + scroll cue sit on it, and a short scroll
// storyline reveals underneath. See docs/design-spec.md §7 for the history
// of this route (it has flipped between "feed-as-landing" and "banner +
// context page" more than once on 2026-07-21; this is the latest state).
import Base from "../layouts/Base.astro";
import { loadVideos, loadTimeline } from "../lib/schema";
import { SITE_URL } from "../config";

const videos = loadVideos();
const timeline = loadTimeline();
const realVideos = videos.filter((v) => !v.sample);
const sampleVideos = videos.filter((v) => v.sample);

const ogImage = `${SITE_URL}/banner/students-wide.jpg`;
---

<Base
  title="Home"
  description="On 20 July 2026, tens of thousands of people marched towards Parliament in New Delhi and were met with tear gas and lathi charges. This is an archive of video posted publicly by the people who were there, each entry linking back to the original post."
  ogImage={ogImage}
  hideHeader
  overlayNav
  hideFooter
>
  <!-- The poster already carries the date/title text; this heading exists
       for SEO and screen readers only, never rendered visibly. -->
  <h1 class="sr-only">20 07 2026 — The Day India Remembered</h1>

  <section class="hero">
    <picture>
      <!-- Desktop / wide viewports: re-rendered 2:1 artwork (source: a fresh
           2x upscale of the newer poster generation, re-encoded here at
           1280/1920/2560w with the same mild-unsharp treatment as the
           portrait crop below). 2:1 is a much closer match to common
           desktop viewport ratios than the old 3:2 crop was, so `cover`
           below now only has to trim a sliver rather than pillarbox. -->
      <source
        media="(min-width: 768px)"
        type="image/webp"
        srcset="/banner/students-wide-1280.webp 1280w, /banner/students-wide-1920.webp 1920w, /banner/students-wide-2560.webp 2560w"
        sizes="100vw"
      />
      <source
        media="(min-width: 768px)"
        type="image/jpeg"
        srcset="/banner/students-wide.jpg"
      />
      <!-- Mobile / narrow viewports: native 864x1822 portrait (~1:2.11),
           close match to a ~1:2.16 phone. Do not offer widths above 864 —
           864x1822 is the highest resolution this illustration has ever
           existed at anywhere (checked the working tree, archive-originals/,
           and every commit in git history — no higher-res source, PNG or
           otherwise, was ever committed); offering a wider candidate would
           just upscale this same source and add bytes for zero extra
           detail.
           The "pixelated" complaint traced to a real, measurable cause: at
           the common 390 CSS px / DPR 3 phone width, the layout needs ~1170
           physical px, but 864w is the largest candidate available, so the
           browser upscales it ~35% and that upscale is what read as soft/
           pixelated (verified via getBoundingClientRect() vs the image's
           natural size in a real render, not guessed). Since no higher-res
           source exists, the fix that's actually possible without
           fabricating detail is: re-encode both candidates from a fresh
           decode with a mild unsharp mask (ffmpeg unsharp, luma amount
           0.4-0.5) before the webp pass, at quality 80 — this measurably
           sharpens the edges the browser's own upscale softens, confirmed
           by comparing before/after crops at the simulated DPR3 scale, and
           it only costs ~12KB on the 864w candidate (216KB -> 228KB), still
           well inside the ~250KB mobile LCP budget. Encoder quality itself
           wasn't the problem — the previous 864w file was already ~q82,
           inside the recommended 80-85 band. -->
      <source
        type="image/webp"
        srcset="/banner/students-portrait-640.webp 640w, /banner/students-portrait-864.webp 864w"
        sizes="100vw"
      />
      <img
        src="/banner/students-portrait.jpg"
        alt="Illustration of riot police holding batons and Delhi Police riot shields standing over injured students on the ground, surrounded by scattered protest placards and Indian flags, with the event's date and title overlaid on the artwork."
        width="800"
        height="1686"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        class="hero-img"
      />
    </picture>

    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="hero-overlay">
      <!-- Scroll cue sits ABOVE the CTA in this stack (unusual order) on
           purpose: the whole overlay is bottom-anchored to --hero-strip-h
           (see .hero-overlay below), so whichever element is LAST in the
           stack ends up glued to that anchor line, right above the values
           strip. Putting the CTA last, not the scroll cue, is what pulls the
           button down off the seated figure's face/torso and onto the
           quieter scattered-papers/book ground area at the bottom of the
           artwork — see the CSS comment on .hero-overlay for the measurement
           this is based on. -->
      <div class="scroll-cue">
        <span class="scroll-cue-chevron" aria-hidden="true"></span>
        <span class="scroll-cue-label">Scroll</span>
      </div>

      <a href="/feed" class="cta-primary">Show me proof</a>
    </div>
  </section>

  <div class="content-col storyline">
    <!-- Memorial lede: the thesis line that opens the storyline, the first
         text read after scrolling past the poster. Date-led and restrained
         to match the archive's documentation-first voice — the epithet is the
         site's own memorial framing, not a claim about any media item. -->
    <section class="reveal lede" data-reveal>
      <p class="lede-kicker">20 July 2026</p>
      <h2 class="lede-title">The Day India Remembered</h2>
      <p class="lede-sub">For many, the darkest day of India&rsquo;s democracy.</p>
    </section>

    <section class="reveal story-block" data-reveal>
      <h2 class="text-lg font-semibold">What happened</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        On 20 July 2026, tens of thousands of people marched towards
        Parliament in New Delhi. Police cut mobile internet, closed metro
        stations, and used tear gas and batons.
      </p>
    </section>

    <section class="reveal story-block" data-reveal>
      <h2 class="text-lg font-semibold">What this is</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        An archive of publicly available video from that day, kept with its
        original sources and labelled by how much of it has actually been
        verified.
      </p>
      <p class="counts">
        {realVideos.length} video{realVideos.length === 1 ? "" : "s"} archived
        &middot; {timeline.length} timeline event{
          timeline.length === 1 ? "" : "s"
        }
        <span class="counts-note">
          + {sampleVideos.length} sample placeholders in the archive, clearly
          marked, not counted above
        </span>
      </p>
    </section>

    <section class="reveal story-block story-block--closing" data-reveal>
      <a href="/feed" class="cta-primary">Show me proof</a>
      <nav class="secondary-links" aria-label="More about this archive">
        <a href="/timeline/">Read the timeline</a>
        <a href="/about/">About this archive</a>
      </nav>
    </section>
  </div>
</Base>

<style>
  .hero {
    position: relative;
    /* Never 100vh on mobile: that includes area the browser chrome can
       cover/uncover, which would clip the CTA. 100svh is the guaranteed
       visible minimum. */
    /* End the poster ABOVE the floating nav rather than behind it. The
       artwork's own values strip runs along its bottom edge, so a full-100svh
       hero puts the strip's second line ("THE TRUTH", "THEM", "THE EVIDENCE"…)
       underneath the opaque nav bar and slices it in half. Reserving the nav's
       height means the whole poster — strip included — is actually visible,
       which is the point of showing it at all. */
    height: calc(100svh - var(--app-nav-h) - env(safe-area-inset-bottom));
    width: 100%;
    overflow: hidden;
    background: var(--color-bg);
    /* The poster's own designed values strip (DOCUMENT THE TRUTH / REMEMBER
       THEM / PRESERVE THE EVIDENCE / HONOR THE COURAGE / THIS ARCHIVE) lives
       along the bottom edge of the artwork, occupying the bottom ~19% of the
       full image height. Now that .hero-img uses a top-anchored `cover` on
       mobile (see below — needed to kill the pillarboxing `contain` caused
       on real phone viewports), that strip is exactly what gets cropped
       first, and by a variable amount depending on how much taller the hero
       box is than the poster's own aspect. 10% is a conservative estimate
       of how much of the strip typically survives, not an exact fraction —
       on short viewports the strip may crop away entirely, which is an
       acceptable trade for losing the pillarboxing. The overlay's own
       max(--hero-strip-h, nav-clearance) floor (below) still guarantees the
       CTA never sits behind the bottom nav even where this estimate is off. */
    --hero-strip-h: 10%;
  }

  @media (min-width: 768px) {
    .hero {
      --hero-strip-h: 13%;
      /* Desktop nav is a fixed left sidebar (no header on the landing
         page either), so it claims no vertical space here — the hero can
         take the full viewport height. */
      height: 100svh;
    }
  }

  .hero-img {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    /* `cover`, not `contain`, on phones. `contain` was tried first to avoid
       cropping the poster at all, on the assumption (never checked against
       a real phone, only a bare 390x844 box) that it would only cost ~10px
       of letterbox per side. On an actual small viewport — address bar
       visible, bottom nav reserved via --app-nav-h — the hero box ends up
       noticeably wider-than-tall relative to the poster's own 0.4742 aspect,
       and `contain` pillarboxed with real, visible black bars down both
       sides (reported by the owner from a live phone screenshot, ~8% of
       width per side). That's the same "black bars on both sides" bug
       desktop had before it switched to `cover` (see the media query
       below) — same fix applies here. Anchored top so the crop comes out of
       the bottom values strip rather than the date/title block at the top,
       which matters far more on the first screenful. --hero-strip-h below
       is now a conservative estimate, not an exact fraction, since how much
       of the strip survives depends on how much the crop takes. */
    object-fit: cover;
    object-position: center top;
  }

  @media (min-width: 768px) {
    .hero-img {
      /* Desktop switches to `cover`: the mobile portrait crop still needs
         `contain` (see above — no wider anchor rescues both ends there),
         but the new 2:1 desktop artwork is close enough to real viewport
         ratios that `cover` only trims a small sliver rather than
         pillarboxing, and it's what actually fills the viewport edge to
         edge (the previous unconditional `contain` was letterboxing every
         desktop width, which is the "black bars on both sides" the owner
         flagged). Anchor bottom, not center, for the same reason as before:
         it puts the entire crop at the top (ample sky/margin above the
         "REC" mark) so the bottom-edge values strip survives at full
         height instead of being shaved down and half-hidden behind the nav. */
      object-fit: cover;
      object-position: center bottom;
    }
  }

  /* Bottom scrim so the illustration label and scroll cue stay legible over
     arbitrary artwork pixels, without darkening the whole poster. Runs all
     the way to the hero's own bottom edge (bottom: 0) on both breakpoints:
     both .hero-img crops now use `cover` (mobile top-anchored, desktop
     bottom-anchored — see below), and how much of the values strip survives
     a `cover` crop varies by the viewport's actual aspect ratio, not just
     the one it was tuned against. Desktop used to stop the scrim short
     (bottom: var(--hero-strip-h)) on the assumption its crop reliably kept
     the strip intact, but real desktop viewports cropped it too, leaving
     the same hard, ugly seam mobile had where the crisp uncropped art met
     the flat page background. Running the scrim to the true edge on both
     means whatever's left of the strip always fades into the page's own
     --color-bg instead of ending in a visible line. */
  .hero-scrim {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 36%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.3) 45%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
  }

  .hero-overlay {
    position: absolute;
    left: 0;
    right: 0;
    /* Anchored above the poster's own values strip (see --hero-strip-h on
       .hero) so the CTA/scroll-cue never sit on top of it — and, as a
       floor, always clears the floating bottom nav (mobile only — fixed at
       the bottom of the viewport there, see Base.astro) even on a viewport
       short enough that the strip's measured height would otherwise
       undercut the nav bar. Desktop overrides this below since its nav is
       a left sidebar with no bottom footprint to clear. */
    bottom: max(
      var(--hero-strip-h),
      calc(var(--app-nav-h) + env(safe-area-inset-bottom) + 0.85rem)
    );
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    padding: 0 1.25rem 0.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-overlay {
      /* No bottom bar to clear on desktop (left sidebar instead) — just
         the strip, plus a small fixed floor for very short viewports. */
      bottom: max(var(--hero-strip-h), 1rem);
    }
  }

  .cta-primary {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-bg);
    padding: 0.85rem 2.25rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  .cta-primary:hover {
    opacity: 0.9;
  }

  .scroll-cue {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-muted);
  }

  .scroll-cue-chevron {
    width: 10px;
    height: 10px;
    border-right: 1.5px solid var(--color-muted);
    border-bottom: 1.5px solid var(--color-muted);
    transform: rotate(45deg);
  }

  .scroll-cue-label {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: no-preference) {
    .scroll-cue {
      animation: scroll-cue-bounce 1.6s ease-in-out infinite;
    }
  }

  @keyframes scroll-cue-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* --- Scroll storyline ------------------------------------------------ */

  .storyline {
    padding-top: 4.5rem;
    padding-bottom: 3rem;
  }

  .story-block {
    padding-top: 4rem;
    padding-bottom: 4rem;
    border-top: 1px solid var(--color-border);
  }

  .story-block:first-child {
    padding-top: 0;
    border-top: none;
  }

  /* --- Memorial lede: opens the storyline (first text after the poster) -- */

  .lede {
    text-align: center;
    padding-bottom: 1.5rem;
  }

  .lede-kicker {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }

  .lede-title {
    margin: 0.7rem 0 0;
    font-size: clamp(1.5rem, 6vw, 2.05rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  .lede-sub {
    margin: 0.85rem auto 0;
    max-width: 26rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  .story-block--closing {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .counts {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .counts-note {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.75rem;
    color: var(--color-tertiary);
  }

  .secondary-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.8125rem;
  }

  .secondary-links a {
    color: var(--color-link);
    text-decoration: none;
  }

  .secondary-links a:hover {
    text-decoration: underline;
  }

  /* Progressive enhancement: sections are visible by default (this rule is
     NOT inside a prefers-reduced-motion or JS-only gate). landing.ts only
     ever ADDS a class that hides them again for the staged-reveal
     animation, and only when JS runs AND the user has no reduced-motion
     preference — see src/scripts/landing.ts. If JS never runs, or the
     IntersectionObserver never fires, content simply stays visible. */
  .reveal {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .reveal.js-enhanced {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 700ms ease,
        transform 700ms ease;
    }

    .reveal.js-enhanced.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script src="../scripts/landing.ts"></script>
