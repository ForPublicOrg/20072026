---
import Base from "../layouts/Base.astro";
import TimelineEvent from "../components/TimelineEvent.astro";
import { loadTimeline, loadVideos } from "../lib/schema";

const events = [...loadTimeline()].sort((a, b) =>
  a.time < b.time ? -1 : a.time > b.time ? 1 : 0,
);
const videos = loadVideos();
const videosById = new Map(videos.map((video) => [video.id, video]));
---

<Base
  title="Timeline"
  description="Chronological timeline of events in the 20.07.2026 archive, each linked to the related video entries."
>
  <div class="content-col py-8">
    <h1 class="text-2xl font-bold tracking-tight">Timeline</h1>
    <p class="mt-2 text-sm leading-relaxed text-muted">
      How a remark in a courtroom became a march on Parliament. The anger was
      already there — a leaked NEET-UG question paper and irregularities in the
      CBSE marking and revaluation process had left students across the country
      waiting on results nobody would account for. What the Chief Justice said
      in May gave it a name.
    </p>
    <p class="mt-3 text-sm leading-relaxed text-muted">
      Each entry links to the reporting it is drawn from, and to the related
      footage held in this archive.
    </p>

    <ol class="mt-8 border-t border-border pt-2">
      {
        events.map((event) => (
          <TimelineEvent
            event={event}
            videos={event.relatedVideoIds
              .map((id) => videosById.get(id))
              .filter((v): v is NonNullable<typeof v> => Boolean(v))}
          />
        ))
      }
    </ol>
  </div>
</Base>
