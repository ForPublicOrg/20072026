---
import Base from "../layouts/Base.astro";
import VerificationBadge from "../components/VerificationBadge.astro";
import { CONTACT_EMAIL, SITE_NAME } from "../config";
import type { VerificationStatus } from "../lib/schema";

const statuses: { status: VerificationStatus; description: string }[] = [
  {
    status: "verified",
    description:
      "Location, date, and source independently confirmed; no signs of manipulation.",
  },
  {
    status: "likely-verified",
    description:
      "Location and date each supported by a strong indicator; full corroboration incomplete.",
  },
  {
    status: "partially-verified",
    description: "Some claims are confirmed; the description states which.",
  },
  {
    status: "unverified",
    description:
      "The default; nothing beyond the existence of the public post has been checked.",
  },
  {
    status: "context-unclear",
    description:
      "The footage may be real, but its claimed date, place, or framing is in question.",
  },
];
---

<Base
  title="About"
  description="What this archive is, what it is not, how verification works, and how to reach us about corrections or takedowns."
>
  <div class="content-col py-8">
    <h1 class="text-2xl font-bold tracking-tight">About</h1>

    <section class="mt-8 border-t border-border pt-6">
      <h2 class="text-lg font-semibold">What this is</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        {SITE_NAME} is a static archive documenting publicly available
        videos, photos, and reporting related to a specific protest event.
        The goal is preservation, discoverability, and historical
        documentation — not commentary. The site clearly distinguishes
        verified from unverified material, preserves attribution to original
        sources, and avoids editorializing.
      </p>
    </section>

    <section class="mt-8 border-t border-border pt-6">
      <h2 class="text-lg font-semibold">What this is not</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        This is not a social platform. There are no user accounts, no
        comments, no likes, and no visitor uploads. There is no realtime
        feed and no backend API — every page is generated ahead of time from
        a reviewed data file.
      </p>
    </section>

    <section id="verification" class="mt-8 border-t border-border pt-6">
      <h2 class="text-lg font-semibold">How verification works</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        Every item displays exactly one verification status. When in doubt,
        the lower status is used. The full policy, including the specific
        criteria for each level, lives in{" "}
        <code>docs/verification-policy.md</code> in the project repository.
      </p>
      <ul class="mt-4 flex flex-col gap-3">
        {
          statuses.map(({ status, description }) => (
            <li class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-3">
              <VerificationBadge status={status} variant="light" />
              <span class="text-sm leading-relaxed text-muted">
                {description}
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-8 border-t border-border pt-6">
      <h2 class="text-lg font-semibold">Sources &amp; attribution</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        Attribution — platform, uploader, and the original public URL — is
        always visible on every entry and is never stripped. Original
        sources are linked directly from each video's page.
      </p>
    </section>

    <section class="mt-8 border-t border-border pt-6">
      <h2 class="text-lg font-semibold">Corrections &amp; takedowns</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        If you see an error, want to provide corroborating information, or
        need to request a takedown, contact{" "}
        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="inline-flex min-h-11 items-center font-medium text-accent no-underline hover:underline"
          >{CONTACT_EMAIL}</a
        >. Material entries are corrected, not deleted, wherever possible;
        if media must be removed, the metadata record is kept with a note so
        the record of the record survives.
      </p>
    </section>

    <section class="mt-8 border-t border-border pt-6">
      <h2 class="text-lg font-semibold">Sample-content notice</h2>
      <p class="mt-2 text-sm leading-relaxed text-muted">
        Some entries in this archive are placeholder sample entries, each
        clearly marked "SAMPLE — placeholder entry" and carrying{" "}
        <code>"sample": true</code> in the underlying data. They exist to
        exercise the pipeline and layout and stand alongside reviewed,
        real-content entries; they are never presented as verified fact.
      </p>
    </section>
  </div>
</Base>
