---
import Base from "../layouts/Base.astro";
import VideoCard from "../components/VideoCard.astro";
import { loadVideos, publicVideos } from "../lib/schema";

const videos = publicVideos(loadVideos()).sort((a, b) => {
  if (a.footageOrigin !== b.footageOrigin) {
    return a.footageOrigin === "participant" ? -1 : 1;
  }
  if (a.date !== b.date) return a.date < b.date ? 1 : -1;
  return a.id < b.id ? 1 : -1;
});
---

<Base
  title="Feed"
  description="An archive of publicly available video, photos, and reporting documenting a specific protest event. Preservation, discoverability, and historical documentation — not commentary."
  fullBleed
>
  <div id="feed" class="feed" role="list" aria-label="Video feed">
    {videos.map((video, index) => <VideoCard video={video} index={index} />)}
  </div>
</Base>

<style>
  .feed {
    height: 100%;
    overflow-y: auto;
    overscroll-behavior-y: contain;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
  }
</style>

<script src="../scripts/feed.ts"></script>
