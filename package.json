{
  "name": "blackdays",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "astro build && wrangler deploy --env=\"\"",
    "deploy:staging": "astro build && wrangler deploy --env staging",
    "samples": "node scripts/generate-samples.mjs",
    "collect": "node scripts/collect.mjs",
    "admin-requests": "node scripts/admin-requests.mjs",
    "admin-tui": "node scripts/admin-tui.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "ink": "^7.1.1",
    "open": "^11.0.0",
    "react": "^19.2.8",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@playwright/test": "^1.61.1",
    "lefthook": "^2.1.10",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
