{
  "name": "blackdays",
  "compatibility_date": "2026-07-21",
  // The site is still a static build. `main` exists only so POSTs to
  // /api/takedown have somewhere to land — see src/worker.ts. With `assets`
  // configured alongside `main`, Cloudflare serves matching static files
  // WITHOUT invoking the Worker, so adding this costs nothing on page loads.
  "main": "./src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      // Private inbox for correction/takedown requests. Nothing in this
      // database is ever rendered back onto the public site.
      "binding": "TAKEDOWNS",
      "database_name": "blackdays-takedowns",
      "database_id": "d3231055-fe3a-4a44-8c43-23238b3d1cae"
    },
    {
      // Private inbox for "Submit a video" requests (link or raw upload) from
      // the home page. Separate database from TAKEDOWNS so the two request
      // types never share a table. migrations_dir MUST be set here — left at
      // the wrangler default ("migrations/") it would collide with the
      // TAKEDOWNS migration folder above and try to apply the wrong schema.
      "binding": "SUBMISSIONS",
      "database_name": "blackdays-video-submissions",
      "database_id": "e666f211-8490-4646-805a-4710ebff88d9",
      "migrations_dir": "migrations/video-submissions"
    }
  ],
  "r2_buckets": [
    {
      // Private landing zone for raw footage uploaded via /api/upload/:id.
      // Deliberately NOT the public blackdays-media bucket: nothing here is
      // ever served publicly — only src/worker.ts (write) and an admin's
      // authenticated `wrangler r2 object get` (read) ever touch it.
      "binding": "UPLOADS",
      "bucket_name": "blackdays-uploads"
    }
  ],
  // Served from an existing zone in the account, so no workers.dev subdomain is
  // needed. Cloudflare creates and manages the DNS record for a custom_domain
  // route automatically. 20072026.com is the permanent domain.
  "routes": [{ "pattern": "20072026.com", "custom_domain": true }],

  // Staging environment used by CI on every pull request (see
  // .github/workflows/deploy.yml and .claude/skills/deploy/SKILL.md).
  "env": {
    "staging": {
      "name": "blackdays-staging",
      // `main`, `assets`, `compatibility_date` are inheritable — no need to
      // repeat them. `d1_databases` is a binding (non-inheritable) and MUST
      // get its own database so test takedown submissions never land in the
      // production table. `routes` is inheritable and MUST be explicitly
      // overridden here — left unset, it would silently reattach the live
      // 20072026.com custom domain to this Worker on every staging deploy
      // (see cloudflare/workers-sdk#13925). Deliberately NOT using
      // `workers_dev: true` here: this account has never registered a
      // workers.dev subdomain (skipped on purpose when the site was first
      // set up — it's a one-time, permanent, account-wide registration) and
      // staging shouldn't be the thing that triggers it. staging.20072026.com
      // is a route on the zone we already own instead.
      "routes": [{ "pattern": "staging.20072026.com", "custom_domain": true }],
      "d1_databases": [
        {
          "binding": "TAKEDOWNS",
          "database_name": "blackdays-takedowns-staging",
          "database_id": "386ab281-46e3-45a5-9d24-3a1a489fb771"
        },
        {
          "binding": "SUBMISSIONS",
          "database_name": "blackdays-video-submissions-staging",
          "database_id": "8de76959-33bc-4f15-9b14-2df7bd2754f7",
          "migrations_dir": "migrations/video-submissions"
        }
      ],
      // Separate bucket from production, unlike blackdays-media — uploads are
      // live user-submitted data, not shared reference content, so a test
      // upload on staging must never land in the production bucket (same
      // reasoning as the staging/production D1 split above).
      "r2_buckets": [
        {
          "binding": "UPLOADS",
          "bucket_name": "blackdays-uploads-staging"
        }
      ]
    }
  }
}
